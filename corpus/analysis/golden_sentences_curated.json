  "by_book": {
    "他们最幸福": {
      "year": 2013,
      "sentences": [
        {"text": "一门心思地朝九晚五去上班，买了车买了房又如何？一门心思地辞职退学去流浪，南极到了北极又如何？真正牛B的人生，应该是：既可以朝九晚五，又能够浪迹天涯。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "缘聚缘散，缘深缘浅，缘分尽了自当别离。", "category": "C-缘分/离别", "chapter": "我的王八蛋"}
      ]
    },
    "乖摸摸头": {
      "year": 2014,
      "sentences": [
        {"text": "善良是一种天赋，善意是一种选择。", "category": "B-善意/善良", "chapter": "自序"},
        {"text": "有种可以对抗命运的力量，叫作善意。", "category": "B-善意/善良", "chapter": "自序"},
        {"text": "缘深缘浅，缘聚缘散，该分手时分手，该重逢时重逢。", "category": "C-缘分/离别", "chapter": "自序"},
        {"text": "情义这东西，一见如故容易，难的是来日方长。真正的朋友，分别十年，见了面就像昨天刚刚分手似的。", "category": "C-缘分/离别", "chapter": "自序"},
        {"text": "世界上还有另一种人，他们既可以朝九晚五，又可以浪荡天涯，比如大冰。", "category": "A-人生哲学/价值观", "chapter": "侠之小者的江湖"},
        {"text": "月无常满时，世事亦有阴晴圆缺。", "category": "C-缘分/离别", "chapter": "小乖"},
        {"text": "时间无情第一，它才不在乎你是否还是一个孩子，你只要稍一耽搁、稍一犹豫，它立马帮你决定故事的结局。", "category": "G-生死/无常", "chapter": "老兵不死"},
        {"text": "命运善嫉，总吝啬赋予世人恒久的平静，总猝不及防地把人一下子塞进过山车。", "category": "G-生死/无常", "chapter": "送你一只喵"},
        {"text": "这一世自己为自己选择的家人。", "category": "F-情感/祝福", "chapter": "乖，摸摸头"},
        {"text": "我的生活是过给我自己的，编剧是我、导演是我、主演是我、观众还是我，不是过给别人看的。", "category": "A-人生哲学/价值观", "chapter": "厦门爱情故事2007"},
        {"text": "这是个缺乏平视的时代。", "category": "D-自由/远方/江湖", "chapter": "一百万个祝福"},
        {"text": "哥，别死啊，要活着回来哈。", "category": "H-口语/特色表达", "chapter": "乖，摸摸头"},
        {"text": "祝你有缘有分有朝一日获得属于你自己的传奇。", "category": "F-情感/祝福", "chapter": "椰子姑娘和漂流瓶"},
        {"text": "我是个游荡江湖的孩子，虽谈不上阅人无数，却也见闻了不知多少故事。", "category": "D-自由/远方/江湖", "chapter": "自序"},
        {"text": "施主，施主请留步，施主别撕书……阿弥陀佛么么哒。", "category": "H-口语/特色表达", "chapter": "银匠大冰的手&银匠大冰的镯子"}
      ]
    },
    "阿弥陀佛么么哒": {
      "year": 2015,
      "sentences": [
        {"text": "善良是一种天性，善意是一种选择。", "category": "B-善意/善良", "chapter": "一个孩子的心愿"},
        {"text": "善意是人性中永恒的向阳面。", "category": "B-善意/善良", "chapter": "一个孩子的心愿"},
        {"text": "选择善意，即选择天性，即选择光明。", "category": "B-善意/善良", "chapter": "一个孩子的心愿"},
        {"text": "选择善意，即是选择幸福。", "category": "B-善意/善良", "chapter": "后记"},
        {"text": "善意如电，来即明，去便复冥。但再电光石火也要去选。", "category": "B-善意/善良", "chapter": "后记"},
        {"text": "该喝醉的时候一定不能少喝，该唱歌的时候一定不要干坐。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "谁说有意思就一定要有意义？", "category": "A-人生哲学/价值观", "chapter": "银匠大冰的手&银匠大冰的镯子"},
        {"text": "真实的人生本就琐碎，如何去桥接、过渡、贯穿，看你自己喽。", "category": "A-人生哲学/价值观", "chapter": "真实的人生本就琐碎"},
        {"text": "到死之前，我们都是需要发育的孩子，从未长大，也从未停止生长。", "category": "E-成长/自我", "chapter": "银匠大冰的手&银匠大冰的镯子"},
        {"text": "普通人就只能扮演路人甲吗？世间大多数传奇，不过是普普通通的人们把心意化作了行动而已。", "category": "B-善意/善良", "chapter": "普通人就只能扮演路人甲吗"},
        {"text": "世上没有什么命中注定。所谓命中注定，都基于你过去和当下有意无意的选择。", "category": "A-人生哲学/价值观", "chapter": "银匠大冰的手&银匠大冰的镯子"},
        {"text": "心随念走，身随缘游，不能靠心情活着，而是靠心态活着。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "缘深缘浅，缘聚缘散，随缘即可，不必攀缘，惜缘即可，不必攀缘。", "category": "C-缘分/离别", "chapter": "铃铛"},
        {"text": "我在路上走着，遇到了你，大家点头微笑，结伴一程。惜缘即可，不必攀缘。同路人而已。", "category": "C-缘分/离别", "chapter": "小善缘"},
        {"text": "无量天尊，哈利路亚，阿弥陀佛么么哒。我心安处即为家。", "category": "H-口语/特色表达", "chapter": "自序"},
        {"text": "在某个层面上而言，个体人性的丰满和完善，即为成长。", "category": "E-成长/自我", "chapter": "厦门爱情故事2007"},
        {"text": "再远的路慢慢走过去就是，心绪是慢悠悠的，脚下也就用不着匆忙赶路。", "category": "A-人生哲学/价值观", "chapter": "铃铛"},
        {"text": "诗难果腹养心肺，酒不解渴润平生。", "category": "D-自由/远方/江湖", "chapter": "银匠大冰的手&银匠大冰的镯子"},
        {"text": "没有过不去，只是再也回不去。", "category": "C-缘分/离别", "chapter": "哭什么哭"},
        {"text": "我是个浪迹天涯的孩子……我有故事，你有酒吗？", "category": "H-口语/特色表达", "chapter": "我有故事，你有酒吗？"}
      ]
    },
    "好吗好的": {
      "year": 2016,
      "sentences": [
        {"text": "平行世界，多元生活，既可以朝九晚五，又能够浪迹天涯。", "category": "A-人生哲学/价值观", "chapter": "后记"},
        {"text": "没有任何一种生活方式是天然带有原罪的。但任何一种长期单一模式的生活，都是在对自己犯罪。", "category": "A-人生哲学/价值观", "chapter": "后记"},
        {"text": "健全的人生理应是多元的人生、多项选择的人生——先认真体验，再负责地选择。", "category": "A-人生哲学/价值观", "chapter": "后记"},
        {"text": "善意是隔空伸出的一只手——《乖，摸摸头》；善意是人性永恒的向阳面——《阿弥陀佛么么哒》；善意是一种人生正确的打开方式——《好吗好的》。", "category": "B-善意/善良", "chapter": "后记"},
        {"text": "善意能消戾，善意能得缘，善意能带业往生，善意能回头是岸。", "category": "B-善意/善良", "chapter": "后记"},
        {"text": "有人说文化可以用四句话表达：植根于内心的修养；无须提醒的自觉；以约束为前提的自由；为他人着想的善良。", "category": "B-善意/善良", "chapter": "后记"},
        {"text": "不过一座普普通通的小城，并不代表自由，也代表不了自由。你若能平视它，自得欢喜，自得清趣。", "category": "D-自由/远方/江湖", "chapter": "某个普通人的选择"},
        {"text": "生命应该用来体验和发现，到死之前，我们都是需要发育的孩子。", "category": "E-成长/自我", "chapter": "后记"},
        {"text": "别怕痛和错，不去经历这一切，你如何能获得那份内心丰盈而强大的力量？", "category": "E-成长/自我", "chapter": "后记"},
        {"text": "因为对年轻人而言，没有比认认真真地去\"犯错\"更酷更有意义的事情了。", "category": "E-成长/自我", "chapter": "后记"},
        {"text": "愿你知行合一，愿你能心安。", "category": "F-情感/祝福", "chapter": "后记"},
        {"text": "前途风光正好，追风赶月莫停留！", "category": "F-情感/祝福", "chapter": "前途风光正好"},
        {"text": "谢谢你买我的书，并有耐心读它。谢谢你们允许我陪着你们长大，也谢谢你们乐意陪着我变老。", "category": "F-情感/祝福", "chapter": "后记"},
        {"text": "打哭你信不信？", "category": "H-口语/特色表达", "chapter": "后记"},
        {"text": "好吗好的。", "category": "H-口语/特色表达", "chapter": "后记"}
      ]
    },
    "我不": {
      "year": 2017,
      "sentences": [
        {"text": "生如逆旅单行道，哪有岁月可回头。", "category": "G-生死/无常", "chapter": "自序"},
        {"text": "有意思比有意义更有意义。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "追风赶月莫停留，平芜尽处是春山。", "category": "F-情感/祝福", "chapter": "自序"},
        {"text": "入世即俗人，但总有一些俗人，俗得和你我不太一样。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "星光不问赶路人，时光不负有心人。", "category": "F-情感/祝福", "chapter": "自序"},
        {"text": "我推崇的价值观是：平行世界，多元生活。既可以朝九晚五，又能够浪迹天涯。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "越是真正的旅行者越懂得去平衡生活。越是理智的旅行者越明白去平视生活。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "常识构建底线，阅历塑造审美，选择换来航向，修行成就慈悲。", "category": "E-成长/自我", "chapter": "自序"},
        {"text": "人无痴无趣不可与交，以其无深情无真气也。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "需求决定关系，没有需求保持友好。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "圆缺无常，八风凛冽。少有永恒，只有永别。", "category": "G-生死/无常", "chapter": "自序"},
        {"text": "人间道是向死而生的，一路生长一路告别。", "category": "G-生死/无常", "chapter": "自序"},
        {"text": "那些动人的故事，大都始于平淡，蕴于普通，却又伏藏在人性关隘处，示现在命运绝境中。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "所谓小善缘：小就是不深不浅，善就是天性使然，缘就是聚合离散。", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "被赞美着的往往也是被绑架着的。", "category": "E-成长/自我", "chapter": "自序"},
        {"text": "愿这一声\"我不\"，能助你涉川。", "category": "F-情感/祝福", "chapter": "后记"},
        {"text": "有缘再聚吧少侠，速速登岸，追风赶月莫停留，平芜尽处是春山。", "category": "F-情感/祝福", "chapter": "后记"}
      ]
    },
    "你坏": {
      "year": 2018,
      "sentences": [
        {"text": "如果非要给我说的书定调，不过三个字：平视、平行、平衡。", "category": "A-人生哲学/价值观", "chapter": "后记"},
        {"text": "不过是因为悲观，所以向阳，因为身处无边黑夜，所以希祈光。", "category": "B-善意/善良", "chapter": "后记"},
        {"text": "于无常处知有情。于有情处知众生。", "category": "G-生死/无常", "chapter": "后记"}
      ]
    },
    "小孩": {
      "year": 2019,
      "sentences": [
        {"text": "浮生恰似冰底水，日夜东流人不知，人们只道我爱写无常中的有情。", "category": "G-生死/无常", "chapter": "后记"},
        {"text": "自洽是最高阶的自尊。自洽是最基本的自在。", "category": "E-成长/自我", "chapter": "小自洽"},
        {"text": "我若自洽，你奈我何。", "category": "E-成长/自我", "chapter": "小自洽"},
        {"text": "平视是最基础的尊重。", "category": "E-成长/自我", "chapter": "小自洽"},
        {"text": "躲得开的，都不是缘分。猜得透的，都不叫人生。", "category": "C-缘分/离别", "chapter": "自序"},
        {"text": "一门心思的浪迹天涯，和一门心思的朝九晚五又有什么区别呢？", "category": "A-人生哲学/价值观", "chapter": "自序"},
        {"text": "愿你永远有心力，去当个小孩。", "category": "F-情感/祝福", "chapter": "后记"},
        {"text": "莫问归期，毋挂念，我有我路向，我知我方向。", "category": "F-情感/祝福", "chapter": "后记"},
        {"text": "越不爱人间，越觉人间好。人间很好，但下辈子不太想来了。", "category": "E-成长/自我", "chapter": "胶东往事"},
        {"text": "生死没的选，当个怎样的凡人应该是可以选的吧。", "category": "G-生死/无常", "chapter": "自序"}
      ]
    },
    "保重": {
      "year": 2022,
      "sentences": [
        {"text": "于无常处知有情，于有情处知众生。", "category": "G-生死/无常", "chapter": "后记"},
        {"text": "无常才是命运。命运善嫉，不容圆满，像个无聊的熊孩子。", "category": "G-生死/无常", "chapter": "工人的女儿"},
        {"text": "生如逆旅单行道，哪有岁月可回头。谁的中年不是一场回不了头的丙察察。", "category": "G-生死/无常", "chapter": "保重"},
        {"text": "保重二字，是我最后的祝福，予她，也是予你的，感恩曾相遇，感恩多年来的相伴。", "category": "C-缘分/离别", "chapter": "后记"},
        {"text": "与君同船渡，书聚如共舟。船有再来日，人或不重逢。", "category": "C-缘分/离别", "chapter": "后记"},
        {"text": "如果可以，读完这本《保重》后，将我忘了吧。我先走了，你好好的。保重。再见。", "category": "C-缘分/离别", "chapter": "后记"},
        {"text": "希望你过得好，如果不好，要相信会好起来，不过是时间。", "category": "F-情感/祝福", "chapter": "后记"},
        {"text": "每个人都有朋友，却又孤独得要命。所以，到了一定年纪，每个人都需要有个忘年交。", "category": "E-成长/自我", "chapter": "一点真心"},
        {"text": "大千世界，无挂无碍。自去自来，自由自在。要生便生，莫找替代。", "category": "D-自由/远方/江湖", "chapter": "末日书店"},
        {"text": "我若哪天活腻歪了，先挂了，欢送会时亲友不用烧纸钱，烧《藏地诗篇》。", "category": "H-口语/特色表达", "chapter": "还没死"}
      ]
    }
  },

